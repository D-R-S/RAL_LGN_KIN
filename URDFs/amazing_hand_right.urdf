<?xml version="1.0"?>
<!--
  Amazing Hand (right) — simplified URDF for lgn_hand_ik testing
  ---------------------------------------------------------------
  4 fingers:  index, middle, ring, pinky
  Each finger: 2 DOF
    joint_*_abd   — abduction/adduction  (axis: 0 0 1, z-axis, side-to-side)
    joint_*_flex  — flexion/extension    (axis: 0 1 0, y-axis, curl)
  Differential drive mapping (per finger, handled in hand_ik_node):
    q = B * u,  B = [[0.5, 0.5],[0.5,-0.5]]
  All dimensions in metres.  Origin = palm centre at wrist face.
-->
<robot name="amazing_hand_right">

  <!-- ═══════════════════════════════════════════════════════════════
       PALM
  ═══════════════════════════════════════════════════════════════ -->
  <link name="palm">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.08 0.10 0.08"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="0.08 0.10 0.08"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0.04"/>
      <inertia ixx="0.0002" iyy="0.0002" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ═══════════════════════════════════════════════════════════════
       FINGER MACRO (repeated 4×)
       Naming: {name} ∈ {index, middle, ring, pinky}
       palm_offset_y: lateral spacing from palm centre
  ═══════════════════════════════════════════════════════════════ -->

  <!-- ─────────────────────────────── INDEX ──────────────────────── -->

  <!-- abduction joint: rotates proximal link side-to-side -->
  <joint name="joint_index_abd" type="revolute">
    <parent link="palm"/>
    <child  link="index_proximal"/>
    <origin xyz="0.025 0.035 0.08" rpy="0 0 0"/>
    <axis   xyz="0 0 1"/>
    <limit  lower="-0.35" upper="0.35" effort="1.5" velocity="3.0"/>
    <dynamics damping="0.01" friction="0.005"/>
  </joint>

  <link name="index_proximal">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.008" length="0.04"/></geometry>
      <material name="light_grey"><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.008" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.012"/>
      <origin xyz="0 0 0.02"/>
      <inertia ixx="2e-6" iyy="2e-6" izz="5e-7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="joint_index_flex" type="revolute">
    <parent link="index_proximal"/>
    <child  link="index_distal"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  lower="-0.1" upper="1.57" effort="1.5" velocity="3.0"/>
    <dynamics damping="0.01" friction="0.005"/>
  </joint>

  <link name="index_distal">
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.007" length="0.04"/></geometry>
      <material name="light_grey"><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><cylinder radius="0.007" length="0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.010"/>
      <origin xyz="0 0 0.02"/>
      <inertia ixx="1.5e-6" iyy="1.5e-6" izz="4e-7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- fingertip sphere — contact detection target -->
  <joint name="joint_index_tip" type="fixed">
    <parent link="index_distal"/>
    <child  link="index_tip"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
  </joint>
  <link name="index_tip">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.009"/></geometry>
      <material name="skin"><color rgba="0.9 0.75 0.65 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.009"/></geometry>
    </collision>
    <inertial>
      <mass value="0.003"/>
      <inertia ixx="1e-7" iyy="1e-7" izz="1e-7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ─────────────────────────────── MIDDLE ──────────────────────── -->

  <joint name="joint_middle_abd" type="revolute">
    <parent link="palm"/>
    <child  link="middle_proximal"/>
    <origin xyz="0.008 0.035 0.08" rpy="0 0 0"/>
    <axis   xyz="0 0 1"/>
    <limit  lower="-0.35" upper="0.35" effort="1.5" velocity="3.0"/>
    <dynamics damping="0.01" friction="0.005"/>
  </joint>

  <link name="middle_proximal">
    <visual>
      <origin xyz="0 0 0.022" rpy="0 0 0"/>
      <geometry><cylinder radius="0.008" length="0.044"/></geometry>
      <material name="light_grey"><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.022" rpy="0 0 0"/>
      <geometry><cylinder radius="0.008" length="0.044"/></geometry>
    </collision>
    <inertial>
      <mass value="0.013"/>
      <origin xyz="0 0 0.022"/>
      <inertia ixx="2.2e-6" iyy="2.2e-6" izz="5e-7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="joint_middle_flex" type="revolute">
    <parent link="middle_proximal"/>
    <child  link="middle_distal"/>
    <origin xyz="0 0 0.044" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  lower="-0.1" upper="1.57" effort="1.5" velocity="3.0"/>
    <dynamics damping="0.01" friction="0.005"/>
  </joint>

  <link name="middle_distal">
    <visual>
      <origin xyz="0 0 0.022" rpy="0 0 0"/>
      <geometry><cylinder radius="0.007" length="0.042"/></geometry>
      <material name="light_grey"><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.022" rpy="0 0 0"/>
      <geometry><cylinder radius="0.007" length="0.042"/></geometry>
    </collision>
    <inertial>
      <mass value="0.011"/>
      <origin xyz="0 0 0.022"/>
      <inertia ixx="1.8e-6" iyy="1.8e-6" izz="4e-7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="joint_middle_tip" type="fixed">
    <parent link="middle_distal"/>
    <child  link="middle_tip"/>
    <origin xyz="0 0 0.044" rpy="0 0 0"/>
  </joint>
  <link name="middle_tip">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.009"/></geometry>
      <material name="skin"><color rgba="0.9 0.75 0.65 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.009"/></geometry>
    </collision>
    <inertial>
      <mass value="0.003"/>
      <inertia ixx="1e-7" iyy="1e-7" izz="1e-7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ─────────────────────────────── RING ──────────────────────── -->

  <joint name="joint_ring_abd" type="revolute">
    <parent link="palm"/>
    <child  link="ring_proximal"/>
    <origin xyz="-0.009 0.033 0.08" rpy="0 0 0"/>
    <axis   xyz="0 0 1"/>
    <limit  lower="-0.35" upper="0.35" effort="1.5" velocity="3.0"/>
    <dynamics damping="0.01" friction="0.005"/>
  </joint>

  <link name="ring_proximal">
    <visual>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <geometry><cylinder radius="0.008" length="0.040"/></geometry>
      <material name="light_grey"><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <geometry><cylinder radius="0.008" length="0.040"/></geometry>
    </collision>
    <inertial>
      <mass value="0.012"/>
      <origin xyz="0 0 0.020"/>
      <inertia ixx="2e-6" iyy="2e-6" izz="5e-7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="joint_ring_flex" type="revolute">
    <parent link="ring_proximal"/>
    <child  link="ring_distal"/>
    <origin xyz="0 0 0.040" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  lower="-0.1" upper="1.57" effort="1.5" velocity="3.0"/>
    <dynamics damping="0.01" friction="0.005"/>
  </joint>

  <link name="ring_distal">
    <visual>
      <origin xyz="0 0 0.019" rpy="0 0 0"/>
      <geometry><cylinder radius="0.007" length="0.038"/></geometry>
      <material name="light_grey"><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.019" rpy="0 0 0"/>
      <geometry><cylinder radius="0.007" length="0.038"/></geometry>
    </collision>
    <inertial>
      <mass value="0.010"/>
      <origin xyz="0 0 0.019"/>
      <inertia ixx="1.5e-6" iyy="1.5e-6" izz="4e-7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="joint_ring_tip" type="fixed">
    <parent link="ring_distal"/>
    <child  link="ring_tip"/>
    <origin xyz="0 0 0.038" rpy="0 0 0"/>
  </joint>
  <link name="ring_tip">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.009"/></geometry>
      <material name="skin"><color rgba="0.9 0.75 0.65 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.009"/></geometry>
    </collision>
    <inertial>
      <mass value="0.003"/>
      <inertia ixx="1e-7" iyy="1e-7" izz="1e-7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ─────────────────────────────── PINKY ──────────────────────── -->

  <joint name="joint_pinky_abd" type="revolute">
    <parent link="palm"/>
    <child  link="pinky_proximal"/>
    <origin xyz="-0.025 0.030 0.08" rpy="0 0 0"/>
    <axis   xyz="0 0 1"/>
    <limit  lower="-0.35" upper="0.35" effort="1.5" velocity="3.0"/>
    <dynamics damping="0.01" friction="0.005"/>
  </joint>

  <link name="pinky_proximal">
    <visual>
      <origin xyz="0 0 0.017" rpy="0 0 0"/>
      <geometry><cylinder radius="0.007" length="0.034"/></geometry>
      <material name="light_grey"><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.017" rpy="0 0 0"/>
      <geometry><cylinder radius="0.007" length="0.034"/></geometry>
    </collision>
    <inertial>
      <mass value="0.010"/>
      <origin xyz="0 0 0.017"/>
      <inertia ixx="1.5e-6" iyy="1.5e-6" izz="4e-7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="joint_pinky_flex" type="revolute">
    <parent link="pinky_proximal"/>
    <child  link="pinky_distal"/>
    <origin xyz="0 0 0.034" rpy="0 0 0"/>
    <axis   xyz="0 1 0"/>
    <limit  lower="-0.1" upper="1.57" effort="1.5" velocity="3.0"/>
    <dynamics damping="0.01" friction="0.005"/>
  </joint>

  <link name="pinky_distal">
    <visual>
      <origin xyz="0 0 0.016" rpy="0 0 0"/>
      <geometry><cylinder radius="0.006" length="0.032"/></geometry>
      <material name="light_grey"><color rgba="0.75 0.75 0.75 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.016" rpy="0 0 0"/>
      <geometry><cylinder radius="0.006" length="0.032"/></geometry>
    </collision>
    <inertial>
      <mass value="0.008"/>
      <origin xyz="0 0 0.016"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="3e-7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="joint_pinky_tip" type="fixed">
    <parent link="pinky_distal"/>
    <child  link="pinky_tip"/>
    <origin xyz="0 0 0.032" rpy="0 0 0"/>
  </joint>
  <link name="pinky_tip">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
      <material name="skin"><color rgba="0.9 0.75 0.65 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.008"/></geometry>
    </collision>
    <inertial>
      <mass value="0.003"/>
      <inertia ixx="1e-7" iyy="1e-7" izz="1e-7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

</robot>
